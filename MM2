local function HasTool(p, n)
    if not p or not p.Character then return false end
    return p.Backpack:FindFirstChild(n) ~= nil or p.Character:FindFirstChild(n) ~= nil
end

local function UpdateMM2RoleESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == LocalPlayer or not plr.Character then continue end
        local char     = plr.Character
        local hasKnife = HasTool(plr, "Knife")
        local hasGun   = HasTool(plr, "Gun")
        local isInno   = not hasKnife and not hasGun

        local function ApplyHL(name, enabled, color)
            local hl = char:FindFirstChild(name)
            if enabled then
                if not hl then
                    hl = Instance.new("Highlight")
                    hl.Name                = name
                    hl.FillColor           = color
                    hl.OutlineColor        = color
                    hl.FillTransparency    = 0.5
                    hl.OutlineTransparency = 0
                    hl.Parent              = char
                end
            else
                if hl then hl:Destroy() end
            end
        end

        ApplyHL("InnocentHighlight", State.RoleESP.InnocentEnabled and isInno,   State.RoleESP.InnocentColor)
        ApplyHL("SheriffHighlight",  State.RoleESP.SheriffEnabled  and hasGun,   State.RoleESP.SheriffColor)
        ApplyHL("MurdererHighlight", State.RoleESP.MurdererEnabled and hasKnife, State.RoleESP.MurdererColor)
    end

    if State.RoleESP.GunDropEnabled then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "GunDrop" and obj:IsA("BasePart") and not obj:FindFirstChild("GunDropHighlight") then
                local h = Instance.new("Highlight")
                h.Name               = "GunDropHighlight"
                h.FillColor          = State.RoleESP.GunDropColor
                h.OutlineColor       = State.RoleESP.GunDropColor
                h.FillTransparency   = 0.3
                h.OutlineTransparency= 0
                h.Parent             = obj
            end
        end
    else
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "GunDrop" then
                local h = obj:FindFirstChild("GunDropHighlight"); if h then h:Destroy() end
            end
        end
    end
end

