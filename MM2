local function SetupTPWalk()
    Drop("TPWalk")
    if not State.Movement.TPWalk then return end
    if State.Movement.TPWalkTween then
        Conn("TPWalk", RunService.Heartbeat:Connect(function(dt)
            local root = GetRoot(LocalPlayer)
            local hum  = GetHumanoid(LocalPlayer)
            if not root or not hum then return end
            local md = hum.MoveDirection
            if md.Magnitude < 0.1 then return end
            local flat = Vector3.new(md.X, 0, md.Z)
            if flat.Magnitude < 0.01 then flat = md end
            TweenService:Create(root, TweenInfo.new(dt, Enum.EasingStyle.Linear), {
                CFrame = CFrame.new(
                    root.Position + md * State.Movement.TPWalkSpeed * dt,
                    root.Position + md * State.Movement.TPWalkSpeed * dt + flat.Unit
                )
            }):Play()
        end))
    else
        Conn("TPWalk", RunService.Heartbeat:Connect(function()
            local root = GetRoot(LocalPlayer)
            local hum  = GetHumanoid(LocalPlayer)
            if not root or not hum then return end
            local md = hum.MoveDirection
            if md.Magnitude < 0.1 then return end
            local flat = Vector3.new(md.X, 0, md.Z)
            if flat.Magnitude < 0.01 then flat = md end
            local tp = root.Position + md * State.Movement.TPWalkSpeed * 0.05
            root.CFrame = CFrame.new(tp, tp + flat.Unit)
        end))
    end
end

local function ApplyWalkSpeed()
