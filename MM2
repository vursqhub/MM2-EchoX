Conn("RenderMain", RunService.RenderStepped:Connect(function(dt)
    local cam = GetCamera()
    _vpCenter = Vector2.new(cam.ViewportSize.X * 0.5, cam.ViewportSize.Y * 0.5)
    _rainbowHueAimbot = (_rainbowHueAimbot + dt * State.Aimbot.RainbowSpeed) % 1
    _rainbowHueESP    = (_rainbowHueESP    + dt * State.ESP.RainbowSpeed)    % 1
    local rcA = Color3.fromHSV(_rainbowHueAimbot, 1, 1)
    local rcE = Color3.fromHSV(_rainbowHueESP,    1, 1)
    UpdateFOVCircle(State.Aimbot.RainbowFOV and rcA or State.Aimbot.Color, State.Aimbot.Enabled)
    UpdateTBCrosshair()
    if State.Aimbot.Enabled then RunAimbot() end
    RunTriggerbot(dt)
    UpdateESP(rcE)
end))

Conn("RoleESP", RunService.Heartbeat:Connect(function(dt)
    _roleESPTimer = _roleESPTimer + dt
    if _roleESPTimer < 0.25 then return end
    _roleESPTimer = 0; UpdateMM2RoleESP()
end))

