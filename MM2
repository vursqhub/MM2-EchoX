local _visitedCoins = {}

local function getNearestCoin(hrp)
    local nearest, nearestDist = nil, math.huge
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "Coin_Server" and obj:IsA("BasePart") and not _visitedCoins[obj] then
            local d = (obj.Position - hrp.Position).Magnitude
            if d < nearestDist then nearestDist = d; nearest = obj end
        end
    end
    if not nearest then
        _visitedCoins = {}
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name == "Coin_Server" and obj:IsA("BasePart") then
                local d = (obj.Position - hrp.Position).Magnitude
                if d < nearestDist then nearestDist = d; nearest = obj end
            end
        end
    end
    return nearest, nearestDist
end

local function stopCoinFarm()
    State.Farming.CoinFarm = false; Drop("CoinFarmNoclip"); _visitedCoins = {}
end

local function isInLobby()
    local char = LocalPlayer.Character; if not char then return true end
    local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return true end
    return hum.Health <= 0 or hum:GetState() == Enum.HumanoidStateType.Dead
end

local function coinsExistInWorkspace()
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "Coin_Server" and obj:IsA("BasePart") then return true end
    end
    return false
end

local function startCoinFarmLoop()
    if State.Farming.CoinFarm then return end
    State.Farming.CoinFarm = true; _visitedCoins = {}
    Conn("CoinFarmNoclip", RunService.Stepped:Connect(function()
        if LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end))
    task.spawn(function()
        while State.Farming.CoinFarm do
            if isInLobby() then stopCoinFarm(); break end
            local char = LocalPlayer.Character; if not char then task.wait(0.5); break end
            local hrp  = char:FindFirstChild("HumanoidRootPart"); if not hrp then task.wait(0.5); break end
            local coin, dist = getNearestCoin(hrp); if not coin then task.wait(0.5); break end
            _visitedCoins[coin] = true
            local duration = math.max(dist / State.Farming.CoinFarmSpeed, 0.2)
            local coinPos  = coin.Position
            local targetCF = CFrame.new(coinPos.X, coinPos.Y + (hrp.Size.Y / 2), coinPos.Z)
            local tw = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.Out), { CFrame = targetCF })
            tw:Play(); tw.Completed:Wait()
            task.wait(math.max(State.Farming.CoinFarmDelay, 0))
        end
    end)
end

LocalPlayer.CharacterAdded:Connect(function(character)
    stopCoinFarm()
    local humanoid = character:WaitForChild("Humanoid")
    humanoid.Died:Connect(function() stopCoinFarm() end)
    if State.Farming.CoinFarmWanted then
        task.spawn(function()
            local waited = 0
            while waited < 60 do
                if coinsExistInWorkspace() then
                    task.wait(0.5)
                    if State.Farming.CoinFarmWanted and not State.Farming.CoinFarm then
                        startCoinFarmLoop()
                    end
                    return
                end
                task.wait(1); waited = waited + 1
            end
        end)
    end
end)

