local function GetNearestPlayerRoot()
    local sr = GetRoot(LocalPlayer); if not sr then return nil end
    local best, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local r = GetRoot(p)
            if r then local d = (r.Position - sr.Position).Magnitude; if d < bestD then bestD = d; best = r end end
        end
    end
    return best
end

local function GetRandomPlayerRoot()
    local roots = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then local r = GetRoot(p); if r then table.insert(roots, r) end end
    end
    if #roots == 0 then return nil end
    return roots[math.random(1, #roots)]
end

local function SetupOrbit()
    Drop("Orbit"); Drop("OrbitClick")
    OrbitTarget = nil; OrbitAngle = 0; OrbitAutoTimer = 0
    if not State.Movement.Orbit then return end
    if State.Movement.OrbitMode == "click" then
        Conn("OrbitClick", Mouse.Button1Down:Connect(function()
            if not State.Movement.Orbit then return end
            if State.Movement.ClickTP or State.Movement.ClickTweenTP then return end
            local hit = Mouse.Hit; if not hit then return end
            local best, bestD = nil, math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then
                    local r = GetRoot(p)
                    if r then
                        local d = (r.Position - hit.Position).Magnitude
                        if d < 8 and d < bestD then bestD = d; best = r end
                    end
                end
            end
            if best then OrbitTarget = best; OrbitAngle = 0 end
        end))
    end
    Conn("Orbit", RunService.Heartbeat:Connect(function(dt)
        local root = GetRoot(LocalPlayer); if not root then return end
        local mode = State.Movement.OrbitMode
        if mode == "nearest" then
            OrbitTarget = GetNearestPlayerRoot()
        elseif mode == "auto" then
            OrbitAutoTimer = OrbitAutoTimer + dt
            if OrbitAutoTimer >= State.Movement.OrbitCooldown
            or not (OrbitTarget and OrbitTarget.Parent) then
                OrbitAutoTimer = 0; OrbitTarget = GetRandomPlayerRoot()
            end
        end
        if not OrbitTarget or not OrbitTarget.Parent then OrbitTarget = nil; return end
        OrbitAngle = OrbitAngle + math.rad(State.Movement.OrbitSpeed) * dt * 60
        local op = OrbitTarget.Position
                 + Vector3.new(
                     math.cos(OrbitAngle) * State.Movement.OrbitRadius,
                     0,
                     math.sin(OrbitAngle) * State.Movement.OrbitRadius
                   )
        root.CFrame = CFrame.new(op, OrbitTarget.Position)
    end))
end

local function SetupHoverPlayer()
    Drop("HoverPlayer"); Drop("HoverClick")
    HoverTarget = nil
    if not State.Movement.HoverPlayer then return end
    if State.Movement.HoverMode == "click" then
        Conn("HoverClick", Mouse.Button1Down:Connect(function()
            if not State.Movement.HoverPlayer then return end
            if State.Movement.ClickTP or State.Movement.ClickTweenTP then return end
            local hit = Mouse.Hit; if not hit then return end
            local best, bestD = nil, math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and IsAlive(p) then
                    local r = GetRoot(p)
                    if r then
                        local d = (r.Position - hit.Position).Magnitude
                        if d < 12 and d < bestD then bestD = d; best = p end
                    end
                end
            end
            if best then HoverTarget = best; Notify("Hover", "Hovering: " .. (best.DisplayName or best.Name), 2) end
        end))
    end
    Conn("HoverPlayer", RunService.Heartbeat:Connect(function(dt)
        if not State.Movement.HoverPlayer then return end
        local root = GetRoot(LocalPlayer); if not root then return end
        if State.Movement.HoverMode == "nearest" then
            local best, bestD = nil, math.huge
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and IsAlive(p) then
                    local r = GetRoot(p)
                    if r then
                        local d = (r.Position - root.Position).Magnitude
                        if d < bestD then bestD = d; best = p end
                    end
                end
            end
            HoverTarget = best
        end
        if not HoverTarget or not IsAlive(HoverTarget) then HoverTarget = nil; return end
        local tr = GetRoot(HoverTarget); if not tr then return end
        local targetPos = tr.Position + Vector3.new(0, State.Movement.HoverHeight, 0)
        local look      = tr.CFrame.LookVector
        local flatLook  = Vector3.new(look.X, 0, look.Z)
        if flatLook.Magnitude < 0.01 then flatLook = Vector3.new(0, 0, 1) end
        root.CFrame = root.CFrame:Lerp(
            CFrame.new(targetPos, targetPos + flatLook),
            math.clamp(State.Movement.HoverSpeed * dt, 0, 1)
        )
    end))
end

