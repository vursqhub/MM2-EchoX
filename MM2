local function RaycastVisible(tp)
    local char = GetCharacter(LocalPlayer)
    local head = char and char:FindFirstChild("Head")
    if not head then return false end
    local origin = head.Position
    local dir    = tp.Position - origin
    local dist   = dir.Magnitude
    if dist < 0.1 then return true end
    local unit = dir.Unit
    local excl = { char }
    local trav = 0
    for _ = 1, 20 do
        local rp = RaycastParams.new()
        rp.FilterDescendantsInstances = excl
        rp.FilterType = Enum.RaycastFilterType.Exclude
        local res = workspace:Raycast(origin + unit * trav, unit * (dist - trav), rp)
        if not res then return true end
        local hit = res.Instance
        if not hit.CanCollide then
            table.insert(excl, hit)
            trav = (res.Position - origin).Magnitude + 0.05
            if trav >= dist then return true end
        elseif hit:IsDescendantOf(tp.Parent) then
            return true
        else
            return false
        end
    end
    return false
end

local function IsVisible(tp) return not State.Aimbot.WallCheck or RaycastVisible(tp) end

local function PredPos(part, root)
    local v = (State.Aimbot.Prediction and root) and root.AssemblyLinearVelocity or Vector3.zero
    return part.Position + v * (State.Aimbot.Prediction and State.Aimbot.PredictionStrength or 0)
end

local function GetAimPart(char)
    if not char then return nil end
    local n = State.Aimbot.TargetPart or "Head"
    local p = char:FindFirstChild(n)
    if p and p:IsA("BasePart") then return p end
    if n == "Torso" then return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") end
    return char:FindFirstChild("HumanoidRootPart")
end

local function GetTargetSP(player, keepLocked)
    if not player or not IsAlive(player) then return nil end
    if State.Aimbot.TeamCheck and IsTeammate(player) then return nil end
    local char = GetCharacter(player)
    local ap   = GetAimPart(char)
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not ap then return nil end
    local pred = PredPos(ap, root)
    local sp, on = W2S(pred)
    if not on then return nil end
    if not keepLocked then
        local mp = UserInputService:GetMouseLocation()
        if (sp - mp).Magnitude > State.Aimbot.FOV then return nil end
    end
    if not IsVisible(ap) then return nil end
    return sp
end

local function AimScanTarget()
    local mp = UserInputService:GetMouseLocation()
    local best, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and IsAlive(p) and not (State.Aimbot.TeamCheck and IsTeammate(p)) then
            local char = GetCharacter(p)
            local ap   = GetAimPart(char)
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if ap then
                local pred = PredPos(ap, root)
                local sp, on = W2S(pred)
                if on then
                    local d = (sp - mp).Magnitude
                    if d < State.Aimbot.FOV and d < bestD and IsVisible(ap) then
                        bestD = d; best = p
                    end
                end
            end
        end
    end
    return best
end

local function IsAimKeyActive()
    local k = State.Aimbot.LockKey
    if k == "MouseButton2" then return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    elseif k == "MouseButton1" then return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    elseif k == "MouseButton3" then return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton3)
    else
        local ok, kc = pcall(function() return Enum.KeyCode[k] end)
        if ok and kc then return UserInputService:IsKeyDown(kc) end
    end
    return false
end

local function RunAimbot()
    if not State.Aimbot.Enabled then return end
    if not IsAimKeyActive() then
        LockedTarget = nil; _lastTargetName = ""; _lastTargetHP = nil; _totalDamage = 0
        return
    end
    local sp = GetTargetSP(LockedTarget, State.Aimbot.KeepLocked)
    if not sp then
        LockedTarget = AimScanTarget()
        if LockedTarget then
            sp = GetTargetSP(LockedTarget, false)
            local name = LockedTarget.DisplayName or LockedTarget.Name
            if name ~= _lastTargetName then
                _lastTargetName = name; _lastTargetHP = nil; _totalDamage = 0
                Notify("Aimbot", "Tracking: " .. name, 2)
            end
        end
    end
    if not LockedTarget or not sp then return end
    local hum = GetHumanoid(LockedTarget)
    if hum then
        local cur = hum.Health
        if _lastTargetHP ~= nil and cur < _lastTargetHP then
            local dmg = _lastTargetHP - cur
            _totalDamage = _totalDamage + dmg
            Notify("Hit", string.format("%s  −%.0f hp  (total %.0f)", _lastTargetName, dmg, _totalDamage), 1.5)
        end
        _lastTargetHP = cur
    end
    local char  = GetCharacter(LockedTarget)
    local ap    = GetAimPart(char)
    local root  = char and char:FindFirstChild("HumanoidRootPart")
    if not ap then LockedTarget = nil; return end
    local aimPos = PredPos(ap, root)
    local smooth = math.clamp(State.Aimbot.Smoothness, 0.01, 1)
    local camCF  = GetCamera().CFrame
    local dir    = (aimPos - camCF.Position).Unit
    GetCamera().CFrame = camCF:Lerp(CFrame.new(camCF.Position, camCF.Position + dir), smooth)
end

