        for _, f in ipairs(listfiles(CFG_FOLDER)) do
            if not f:match("%.json$") then continue end
            local name = f:match("[/\\]?([^/\\]+)$")
            if name then name = name:gsub("%.json$", ""); if name ~= "" then table.insert(names, name) end end
        end
    end)
    return names
end

local function CFGSave(name)
    if not writefile then return false, "writefile not available" end
    CFGEnsureFolder()
    local ok, data   = pcall(SerializeState);               if not ok  then return false, "serialization failed" end
    local ok2, json  = pcall(HttpService.JSONEncode, HttpService, data); if not ok2 then return false, "JSON encode failed" end
    local ok3        = pcall(writefile, CFG_FOLDER .. "/" .. name .. CFG_EXT, json); if not ok3 then return false, "write failed" end
    return true
end

local function CFGLoad(name)
    if not readfile then return false, "readfile not available" end
    local ok, json = pcall(readfile, CFG_FOLDER .. "/" .. name .. CFG_EXT)
    if not ok or not json or json == "" then return false, "file not found" end
    local ok2, data = pcall(HttpService.JSONDecode, HttpService, json)
    if not ok2 or not data then return false, "JSON decode failed" end
    if data.Aimbot then
        for k, v in pairs(data.Aimbot) do
            if k == "Color" then State.Aimbot.Color = SC3(v) or State.Aimbot.Color
            elseif State.Aimbot[k] ~= nil then State.Aimbot[k] = v end
        end
    end
    if data.ESP then
        for k, v in pairs(data.ESP) do
            if k == "Color" then State.ESP.Color = SC3(v) or State.ESP.Color
            elseif k == "TeamColor" then State.ESP.TeamColor = SC3(v) or State.ESP.TeamColor
            elseif State.ESP[k] ~= nil then State.ESP[k] = v end
        end
        SetupESP()
    end
    if data.RoleESP then
        for k, v in pairs(data.RoleESP) do
            if k:find("Color") then State.RoleESP[k] = SC3(v) or State.RoleESP[k]
            elseif State.RoleESP[k] ~= nil then State.RoleESP[k] = v end
        end
    end
    if data.Movement then
        for k, v in pairs(data.Movement) do if State.Movement[k] ~= nil then State.Movement[k] = v end end
        ApplyWalkSpeed()
        if State.Movement.Fly         then SetupFly()         end
        if State.Movement.Spin        then SetupSpin()        end
        if State.Movement.InfJump     then SetupInfJump()     end
        if State.Movement.Noclip      then SetupNoclip()      end
        if State.Movement.GodMode     then SetupGodMode()     end
        if State.Movement.Orbit       then SetupOrbit()       end
        if State.Movement.HoverPlayer then SetupHoverPlayer() end
    end
    if data.Farming then
        if data.Farming.CoinFarmSpeed then State.Farming.CoinFarmSpeed = data.Farming.CoinFarmSpeed end
        if data.Farming.CoinFarmDelay then State.Farming.CoinFarmDelay = data.Farming.CoinFarmDelay end
    end
    if data.Triggerbot then
        for k, v in pairs(data.Triggerbot) do if State.Triggerbot[k] ~= nil then State.Triggerbot[k] = v end end
    end
    if data.Fullbright ~= nil then State.Fullbright = data.Fullbright; SetupFullbright() end
    if data.NoFog      ~= nil then State.NoFog      = data.NoFog;      SetupNoFog()      end
    if data.NoShadows  ~= nil then State.NoShadows  = data.NoShadows;  SetupNoShadows()  end
    if data.FPSBoost   ~= nil then State.FPSBoost   = data.FPSBoost;   SetupFPSBoost()   end
    if data.AntiFling  ~= nil then State.AntiFling  = data.AntiFling;  SetupAntiFling()  end
    if data.CameraFOV  ~= nil then State.CameraFOV  = data.CameraFOV;  GetCamera().FieldOfView = data.CameraFOV end
    return true
end

local function CFGDelete(name)
    pcall(function() if delfile then delfile(CFG_FOLDER .. "/" .. name .. CFG_EXT) end end)
end

