local function SetAtmo(a, v)
    if not a then return end
    if v.Density  ~= nil then pcall(function() a.Density  = v.Density  end) end
    if v.Haze     ~= nil then pcall(function() a.Haze     = v.Haze     end) end
    if v.Glare    ~= nil then pcall(function() a.Glare    = v.Glare    end) end
    if v.FogBlend ~= nil then pcall(function() a.FogBlend = v.FogBlend end) end
end

local function SetupFullbright()
    if State.Fullbright then
        Lighting.Ambient        = Color3.fromRGB(255, 255, 255)
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
        Lighting.Brightness     = 2
        Lighting.GlobalShadows  = false
        SetAtmo(Lighting:FindFirstChildOfClass("Atmosphere"), { Density = 0, Haze = 0, Glare = 0, FogBlend = 0 })
        for _, fx in ipairs(Lighting:GetChildren()) do
            if fx:IsA("PostEffect") then fx.Enabled = false end
        end
    else
